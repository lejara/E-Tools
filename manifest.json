{
  "manifest_version": 3,
  "name": "Elementor Tools",
  "version": "1.0.0",
  "description": "Time is an Element",
  "browser_specific_settings": {
    "gecko": {
      "id": "elementor-preview-width@solomediagroup.local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Elementor Tools"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "Tools/preview-override.js",
        "Tools/core_utils.js",
        "Tools/multi-select.js",
        "Tools/layer-root-finder.js",
        "Tools/replace-styles.js",
        "Tools/replace-layer.js",
        "Tools/batch-rename.js",
        "Tools/overlay.js",
        "hotkey-defaults.js",
        "hotkeys.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["Tools/page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
